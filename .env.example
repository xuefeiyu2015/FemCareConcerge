# FemCare Concierge — environment configuration
# Copy this file to `.env` and fill in your key to enable the LIVE Gemini (ADK) path.
# If no key is present, main.py automatically runs in deterministic OFFLINE mode.

# Google AI Studio API key (get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Use AI Studio (dev) rather than Vertex AI. Keep False for the hackathon demo.
GOOGLE_GENAI_USE_VERTEXAI=False
